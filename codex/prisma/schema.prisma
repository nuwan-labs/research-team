// Prisma schema for Research Compiler

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id        String     @id @default(cuid())
  name      String
  template  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  artifacts Artifact[]
  builds    Build[]
  citations Citation[]
  auditLogs AuditLog[]
}

model Artifact {
  id        String   @id @default(cuid())
  projectId String
  stage     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stage])
}

model Build {
  id        String      @id @default(cuid())
  projectId String
  number    Int
  status    String
  summary   String
  createdAt DateTime    @default(now())

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tests   BuildTest[]
}

model BuildTest {
  id        String       @id @default(cuid())
  buildId   String
  name      String
  status    String
  severity  String
  message   String

  build Build @relation(fields: [buildId], references: [id], onDelete: Cascade)
}

model Citation {
  id        String   @id @default(cuid())
  projectId String
  title     String
  doi       String?
  source    String
  grade     String
  url       String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String
  buildId   String?
  action    String
  detail    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
